{
  "mcpServers": {
    "ioffice": {
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "IOFFICE_HOST": "${IOFFICE_HOST}",
        "IOFFICE_TOKEN": "${IOFFICE_TOKEN}",
        "IOFFICE_USERNAME": "${IOFFICE_USERNAME}",
        "IOFFICE_PASSWORD": "${IOFFICE_PASSWORD}"
      }
    }
  }
}
